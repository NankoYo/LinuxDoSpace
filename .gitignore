backend/linuxdospace
backend/linuxdospace-*
backend/linuxdospace.exe
backend/upload-parts/
backend/upload-resume-chunk.txt

# 后端嵌入式前端目录中，本地构建生成的静态资源保持忽略。
backend/web/dist/assets/
backend/web/dist/ICON.png
backend/web/dist/logo.png

*.db
*.sqlite
*.sqlite3
*.log

