# Compose / image selection
IMAGE_NAME=ghcr.io/moyeranqianzhi/linuxdospace
IMAGE_TAG=latest
APP_PORT=8080

# Application settings
APP_NAME=LinuxDoSpace
APP_ENV=production
APP_ADDR=:8080
APP_BASE_URL=https://api.example.com
APP_FRONTEND_URL=https://app.example.com
APP_ADMIN_FRONTEND_URL=https://admin.example.com
APP_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
APP_SESSION_COOKIE_NAME=linuxdospace_session
APP_SESSION_SECRET=replace-with-a-long-random-secret
APP_SESSION_TTL=24h
APP_SESSION_SECURE=true
APP_SESSION_BIND_USER_AGENT=true
APP_ADMIN_VERIFICATION_TTL=30m
APP_AUTO_GENERATE_DEV_SECRET=false
APP_ADMIN_USERNAMES=MoYeRanQianZhi,user2996
APP_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
APP_WRITE_TIMEOUT=15s
APP_READ_TIMEOUT=15s
APP_IDLE_TIMEOUT=60s

# Database backend
DATABASE_DRIVER=postgres
DATABASE_POSTGRES_DSN=postgres://linuxdospace:change-me@postgres:5432/linuxdospace?sslmode=disable

# SQLite persistence path
# Keep this only for local development or rollback scenarios.
SQLITE_PATH=/app/data/linuxdospace.sqlite

# Embedded PostgreSQL service defaults used by deploy/docker-compose.yml
POSTGRES_DB=linuxdospace
POSTGRES_USER=linuxdospace
POSTGRES_PASSWORD=change-me

# Linux Do OAuth settings
LINUXDO_OAUTH_CLIENT_ID=
LINUXDO_OAUTH_CLIENT_SECRET=
LINUXDO_OAUTH_REDIRECT_URL=https://api.example.com/v1/auth/callback
LINUXDO_OAUTH_AUTHORIZE_URL=https://connect.linux.do/oauth2/authorize
LINUXDO_OAUTH_TOKEN_URL=https://connect.linux.do/oauth2/token
LINUXDO_OAUTH_USERINFO_URL=https://connect.linux.do/api/user
LINUXDO_OAUTH_SCOPE=user
LINUXDO_OAUTH_ENABLE_PKCE=false

# Cloudflare DNS + Email Routing settings
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_DEFAULT_ROOT_DOMAIN=linuxdo.space
CLOUDFLARE_DEFAULT_ZONE_ID=
CLOUDFLARE_AUTO_BOOTSTRAP_DOMAIN=true
CLOUDFLARE_DEFAULT_USER_QUOTA=1
