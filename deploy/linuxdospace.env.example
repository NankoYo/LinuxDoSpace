# Compose / image 閫夋嫨閰嶇疆
IMAGE_NAME=ghcr.io/moyeranqianzhi/linuxdospace
IMAGE_TAG=latest
APP_PORT=8080

# 搴旂敤鍩虹閰嶇疆
APP_NAME=LinuxDoSpace
APP_ENV=production
APP_ADDR=:8080
APP_BASE_URL=https://space.example.com
APP_FRONTEND_URL=https://space.example.com
APP_ALLOWED_ORIGINS=https://space.example.com
APP_SESSION_COOKIE_NAME=linuxdospace_session
APP_SESSION_SECRET=replace-with-a-long-random-secret
APP_SESSION_TTL=24h
APP_SESSION_SECURE=true
APP_SESSION_BIND_USER_AGENT=true
APP_AUTO_GENERATE_DEV_SECRET=false
APP_ADMIN_USERNAMES=
APP_WRITE_TIMEOUT=15s
APP_READ_TIMEOUT=15s
APP_IDLE_TIMEOUT=60s

# SQLite 鎸佷箙鍖栫洰褰?SQLITE_PATH=/app/data/linuxdospace.sqlite

# Linux Do OAuth 閰嶇疆
LINUXDO_OAUTH_CLIENT_ID=
LINUXDO_OAUTH_CLIENT_SECRET=
LINUXDO_OAUTH_REDIRECT_URL=https://space.example.com/v1/auth/callback
LINUXDO_OAUTH_AUTHORIZE_URL=https://connect.linux.do/oauth2/authorize
LINUXDO_OAUTH_TOKEN_URL=https://connect.linux.do/oauth2/token
LINUXDO_OAUTH_USERINFO_URL=https://connect.linux.do/api/user
LINUXDO_OAUTH_SCOPE=user
LINUXDO_OAUTH_ENABLE_PKCE=false

# Cloudflare 閰嶇疆
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_DEFAULT_ROOT_DOMAIN=linuxdo.space
CLOUDFLARE_DEFAULT_ZONE_ID=
CLOUDFLARE_AUTO_BOOTSTRAP_DOMAIN=true
CLOUDFLARE_DEFAULT_USER_QUOTA=1

